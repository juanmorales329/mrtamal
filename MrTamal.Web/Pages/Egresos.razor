@page "/egresos"
@attribute [Authorize(Roles = "Admin,Gerente,Contador,Usuario")]
@inject ApiService Api
@inject AuthService AuthSvc

<PageTitle>Egresos</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="text-danger mb-0">💸 Egresos</h3>
    <button class="btn btn-danger" @onclick="() => AbrirModal(null)">+ Nuevo Egreso</button>
</div>

<!-- Navegación por mes -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <button class="btn btn-sm btn-outline-secondary" @onclick="MesAnterior">◀</button>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm" style="width:130px" @bind="mesActual" @bind:after="Cargar">
                    @for (int m = 1; m <= 12; m++)
                    {
                        var mes = m;
                        var nombre = new DateTime(2000, mes, 1).ToString("MMMM");
                        <option value="@mes">@nombre</option>
                    }
                </select>
                <select class="form-select form-select-sm" style="width:90px" @bind="anioActual" @bind:after="Cargar">
                    @for (int a = DateTime.Now.Year + 1; a >= DateTime.Now.Year - 5; a--)
                    {
                        <option value="@a">@a</option>
                    }
                </select>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="MesSiguiente">▶</button>
            <span class="badge bg-danger fs-6">@mesAnioTexto</span>
            <button class="btn btn-sm btn-outline-primary ms-auto" @onclick="IrHoy">Hoy</button>
        </div>
    </div>
</div>

@if (lista is null)
{
    <p>Cargando...</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-danger">
                <tr><th>Fecha</th><th>Código</th><th>Descripción</th><th>Cantidad</th><th>Notas</th><th style="width:80px"></th></tr>
            </thead>
            <tbody>
                @{
                    var grupos = lista.GroupBy(e => e.Fecha.Date).OrderByDescending(g => g.Key);
                    foreach (var grupo in grupos)
                    {
                        var totalDia = grupo.Sum(e => e.Cantidad);
                        foreach (var e in grupo.OrderByDescending(x => x.Id))
                        {
                            <tr>
                                <td>@e.Fecha.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-secondary">@e.CodigoCatalogo</span></td>
                                <td>@e.DescripcionCatalogo</td>
                                <td class="text-danger fw-bold">@simbolo @e.Cantidad.ToString("N2")</td>
                                <td class="text-muted small">@e.Notas</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirModal(e)">✏</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(e.Id)">🗑</button>
                                </td>
                            </tr>
                        }
                        <tr style="background:#FFEBEE;border-top:2px solid #EF9A9A">
                            <td colspan="3" class="text-end text-muted small fw-semibold" style="padding:.4rem .9rem">
                                Total @grupo.Key.ToString("dd/MM/yyyy")
                            </td>
                            <td class="fw-bold text-danger" style="padding:.4rem .9rem">@simbolo @totalDia.ToString("N2")</td>
                            <td colspan="2"></td>
                        </tr>
                    }
                }
                @if (!lista.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Sin egresos en este mes</td></tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-danger">
                    <td colspan="3"><strong>Total @mesAnioTexto</strong></td>
                    <td><strong>@simbolo @lista.Sum(e => e.Cantidad).ToString("N2")</strong></td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>
    </div>
}

@if (mostrarModal)
{
    <MovimientoModal Titulo="@(editandoId > 0 ? "Editar Egreso" : "Nuevo Egreso")"
                     Catalogos="catalogosDisponibles"
                     Fecha="@formFecha"
                     CatalogoId="@formCatalogoId"
                     Cantidad="@formCantidad"
                     Notas="@formNotas"
                     Simbolo="@simbolo"
                     TotalAcumuladoDia="@(lista?.Where(e => e.Fecha.Date == formFecha.Date).Sum(e => e.Cantidad) ?? 0)"
                     OnGuardar="Guardar"
                     OnCancelar="() => mostrarModal = false"
                     FechaChanged="OnFormFechaChanged"
                     CatalogoIdChanged="v => formCatalogoId = v"
                     CantidadChanged="v => formCantidad = v"
                     NotasChanged="v => formNotas = v" />
}

@code {
    private List<MovimientoDto>? lista;
    private List<CatalogoDto>? catalogos;
    private List<CatalogoDto>? catalogosDisponibles;
    private int mesActual = DateTime.Now.Month;
    private int anioActual = DateTime.Now.Year;
    private bool mostrarModal;
    private int editandoId;
    private DateTime formFecha = DateTime.Today.AddDays(-1);
    private int formCatalogoId;
    private decimal formCantidad;
    private string? formNotas;
    private string simbolo = "$";

    private string mesAnioTexto => new DateTime(anioActual, mesActual, 1).ToString("MMMM yyyy");

    protected override async Task OnInitializedAsync()
    {
        simbolo = await AuthSvc.GetSimboloMonedaAsync();
        catalogos = await Api.GetCatalogosAsync(TipoCatalogo.Egreso);
        await Cargar();
    }

    private async Task Cargar()
    {
        var desde = new DateTime(anioActual, mesActual, 1);
        var hasta = desde.AddMonths(1).AddDays(-1);
        lista = await Api.GetEgresosAsync(desde, hasta);
    }

    private async Task MesAnterior()
    {
        if (mesActual == 1) { mesActual = 12; anioActual--; }
        else mesActual--;
        await Cargar();
    }

    private async Task MesSiguiente()
    {
        if (mesActual == 12) { mesActual = 1; anioActual++; }
        else mesActual++;
        await Cargar();
    }

    private async Task IrHoy()
    {
        mesActual = DateTime.Now.Month;
        anioActual = DateTime.Now.Year;
        await Cargar();
    }

    private void AbrirModal(MovimientoDto? m)
    {
        editandoId = m?.Id ?? 0;
        formFecha = m?.Fecha ?? DateTime.Today.AddDays(-1);
        formCatalogoId = catalogos?.FirstOrDefault()?.Id ?? 0;
        formCantidad = m?.Cantidad ?? 0;
        formNotas = m?.Notas;
        mostrarModal = true;
        ActualizarCatalogosDisponibles();
    }

    private void ActualizarCatalogosDisponibles()
    {
        if (editandoId > 0 || lista is null || catalogos is null)
        {
            catalogosDisponibles = catalogos;
            return;
        }
        var usadosEnFecha = lista
            .Where(e => e.Fecha.Date == formFecha.Date)
            .Select(e => e.CodigoCatalogo)
            .ToHashSet();
        catalogosDisponibles = catalogos.Where(c => !usadosEnFecha.Contains(c.Codigo)).ToList();
        formCatalogoId = catalogosDisponibles?.FirstOrDefault()?.Id ?? 0;
    }

    private void OnFormFechaChanged(DateTime fecha)
    {
        formFecha = fecha;
        ActualizarCatalogosDisponibles();
    }

    private async Task Guardar()
    {
        try
        {
            if (editandoId > 0)
                await Api.UpdateEgresoAsync(editandoId, new(formFecha, formCatalogoId, formCantidad, formNotas));
            else
                await Api.CreateEgresoAsync(new(formFecha, formCatalogoId, formCantidad, formNotas));
            mostrarModal = false;
            await Cargar();
        }
        catch { }
    }

    private async Task Eliminar(int id)
    {
        await Api.DeleteEgresoAsync(id);
        await Cargar();
    }
}
