@page "/reportes"
@attribute [Authorize]
@inject ApiService Api
@inject IJSRuntime JS
@inject AuthService AuthSvc

<PageTitle>Reportes</PageTitle>
<h3>📊 Reportes</h3>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <!-- Tipo -->
            <div class="col-md-3">
                <label class="form-label fw-bold">Tipo de Reporte</label>
                <select class="form-select" @bind="tipoReporte" @bind:after="OnTipoChanged">
                    <option value="0">📅 Diario</option>
                    <option value="1">📆 Semanal</option>
                    <option value="2">🗓 Mensual</option>
                    <option value="3">📈 Comparación Anual</option>
                    <option value="4">📊 Comparación por Mes</option>
                </select>
            </div>

            <!-- Diario: seleccionar fecha -->
            @if (tipoReporte == 0)
            {
                <div class="col-md-2">
                    <label class="form-label fw-bold">Fecha</label>
                    <input type="date" class="form-control" @bind="fechaDiaria" />
                </div>
            }

            <!-- Semanal: seleccionar semana -->
            @if (tipoReporte == 1)
            {
                <div class="col-md-2">
                    <label class="form-label fw-bold">Desde</label>
                    <input type="date" class="form-control" @bind="semanaDesde" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Hasta</label>
                    <input type="date" class="form-control" @bind="semanaHasta" />
                </div>
            }

            <!-- Mensual: mes y año -->
            @if (tipoReporte == 2)
            {
                <div class="col-md-2">
                    <label class="form-label fw-bold">Mes</label>
                    <select class="form-select" @bind="mesSeleccionado">
                        @for (int m = 1; m <= 12; m++)
                        {
                            var mes = m;
                            var nombreMes = new DateTime(2000, mes, 1).ToString("MMMM");
                            <option value="@mes">@nombreMes</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Año</label>
                    <select class="form-select" @bind="anio">
                        @for (int a = DateTime.Now.Year; a >= DateTime.Now.Year - 5; a--)
                        {
                            <option value="@a">@a</option>
                        }
                    </select>
                </div>
            }

            <!-- Comparación anual -->
            @if (tipoReporte == 3)
            {
                <div class="col-md-2">
                    <label class="form-label fw-bold">Año 1</label>
                    <input type="number" class="form-control" @bind="anio" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Año 2</label>
                    <input type="number" class="form-control" @bind="anioComparacion" />
                </div>
            }

            <!-- Comparación mensual -->
            @if (tipoReporte == 4)
            {
                <div class="col-md-2">
                    <label class="form-label fw-bold">Año</label>
                    <input type="number" class="form-control" @bind="anio" />
                </div>
            }

            <div class="col-md-2 d-flex gap-2 flex-wrap">
                <button class="btn btn-primary" @onclick="Generar" disabled="@cargando">
                    @(cargando ? "⏳" : "🔍 Generar")
                </button>
                @if (resumen is not null)
                {
                    <button class="btn btn-danger" @onclick="DescargarPdf" disabled="@descargando">
                        @(descargando ? "⏳" : "📄 PDF")
                    </button>
                    <button class="btn btn-success" @onclick="DescargarExcel" disabled="@descargandoExcel">
                        @(descargandoExcel ? "⏳" : "📊 Excel")
                    </button>
                }
            </div>
        </div>

        <!-- Indicador del período seleccionado -->
        @if (periodoTexto is not null)
        {
            <div class="mt-2">
                <span class="badge bg-secondary fs-6">📅 @periodoTexto</span>
            </div>
        }
    </div>
</div>

@if (resumen is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="border-left:5px solid #4CAF50 !important">
                <div class="card-body text-center">
                    <div class="text-muted small">Total Ingresos</div>
                    <h3 class="text-success">@simbolo @resumen.TotalIngresos.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="border-left:5px solid #F44336 !important">
                <div class="card-body text-center">
                    <div class="text-muted small">Total Egresos</div>
                    <h3 class="text-danger">@simbolo @resumen.TotalEgresos.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="border-left:5px solid #2196F3 !important">
                <div class="card-body text-center">
                    <div class="text-muted small">Balance</div>
                    <h3 class="@(resumen.Balance >= 0 ? "text-primary" : "text-warning")">
                        @simbolo @resumen.Balance.ToString("N2")
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráficas -->
    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold">Ingresos vs Egresos</div>
                <div class="card-body" style="position:relative;height:240px">
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold">Distribución</div>
                <div class="card-body" style="position:relative;height:240px">
                    <canvas id="doughnutChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    @if (resumen.Comparaciones?.Any() == true)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-bold">Comparación</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr><th>Período</th><th>Ingresos</th><th>Egresos</th><th>Balance</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var c in resumen.Comparaciones)
                        {
                            <tr>
                                <td class="fw-bold">@c.Periodo</td>
                                <td class="text-success">@simbolo @c.TotalIngresos.ToString("N2")</td>
                                <td class="text-danger">@simbolo @c.TotalEgresos.ToString("N2")</td>
                                <td class="@(c.Balance >= 0 ? "text-primary" : "text-warning") fw-bold">
                                    @simbolo @c.Balance.ToString("N2")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header" style="background:#E8F5E9;color:#2E7D32">
                    💰 Ingresos (@resumen.Ingresos.Count)
                </div>
                <div class="card-body p-0" style="max-height:300px;overflow-y:auto">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Fecha</th><th>Tipo</th><th>Cantidad</th></tr></thead>
                        <tbody>
                            @foreach (var i in resumen.Ingresos)
                            {
                                <tr>
                                    <td>@i.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>@i.Descripcion</td>
                                    <td class="text-success fw-bold">@simbolo @i.Cantidad.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header" style="background:#FFEBEE;color:#C62828">
                    💸 Egresos (@resumen.Egresos.Count)
                </div>
                <div class="card-body p-0" style="max-height:300px;overflow-y:auto">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Fecha</th><th>Tipo</th><th>Cantidad</th></tr></thead>
                        <tbody>
                            @foreach (var e in resumen.Egresos)
                            {
                                <tr>
                                    <td>@e.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>@e.Descripcion</td>
                                    <td class="text-danger fw-bold">@simbolo @e.Cantidad.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int tipoReporte = 2;
    private DateTime fechaDiaria = DateTime.Today;
    private DateTime semanaDesde = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + 1);
    private DateTime semanaHasta = DateTime.Today.AddDays(7 - (int)DateTime.Today.DayOfWeek);
    private int mesSeleccionado = DateTime.Now.Month;
    private int anio = DateTime.Now.Year;
    private int anioComparacion = DateTime.Now.Year - 1;
    private bool cargando, descargando, descargandoExcel;
    private ReporteResumen? resumen;
    private string simbolo = "$";
    private string? periodoTexto;

    protected override async Task OnInitializedAsync()
    {
        simbolo = await AuthSvc.GetSimboloMonedaAsync();
        OnTipoChanged();
    }

    private void OnTipoChanged()
    {
        resumen = null;
        periodoTexto = tipoReporte switch
        {
            0 => $"Día: {fechaDiaria:dd/MM/yyyy}",
            1 => $"Semana: {semanaDesde:dd/MM/yyyy} al {semanaHasta:dd/MM/yyyy}",
            2 => $"Mes: {new DateTime(anio, mesSeleccionado, 1):MMMM yyyy}",
            3 => $"Comparación: {anio} vs {anioComparacion}",
            4 => $"Meses del año {anio}",
            _ => null
        };
    }

    private async Task Generar()
    {
        cargando = true;
        OnTipoChanged();
        resumen = await Api.GetReporteAsync(BuildRequest());
        cargando = false;

        if (resumen is not null)
        {
            await Task.Delay(100);
            await RenderizarGraficos();
        }
    }

    private async Task RenderizarGraficos()
    {
        try
        {
            if (resumen!.Comparaciones?.Any() == true)
            {
                var labels = resumen.Comparaciones.Select(c => c.Periodo).ToArray();
                var ing = resumen.Comparaciones.Select(c => (double)c.TotalIngresos).ToArray();
                var egr = resumen.Comparaciones.Select(c => (double)c.TotalEgresos).ToArray();
                await JS.InvokeVoidAsync("renderBarChart", "barChart", labels, ing, egr);
            }
            else
            {
                await JS.InvokeVoidAsync("renderBarChart", "barChart",
                    new[] { "Ingresos", "Egresos" },
                    new[] { (double)resumen!.TotalIngresos, 0 },
                    new[] { 0, (double)resumen.TotalEgresos });
            }
            await JS.InvokeVoidAsync("renderDoughnutChart", "doughnutChart",
                (double)resumen!.TotalIngresos, (double)resumen.TotalEgresos);
        }
        catch { }
    }

    private async Task DescargarPdf()
    {
        descargando = true;
        var pdf = await Api.GetReportePdfAsync(BuildRequest());
        if (pdf is not null)
            await JS.InvokeVoidAsync("downloadPdf", Convert.ToBase64String(pdf), $"reporte_{DateTime.Now:yyyyMMdd}.pdf");
        descargando = false;
    }

    private async Task DescargarExcel()
    {
        descargandoExcel = true;
        var excel = await Api.GetReporteExcelAsync(BuildRequest());
        if (excel is not null)
            await JS.InvokeVoidAsync("downloadFile", Convert.ToBase64String(excel), $"reporte_{DateTime.Now:yyyyMMdd}.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        descargandoExcel = false;
    }

    private ReporteRequest BuildRequest()
    {
        return tipoReporte switch
        {
            0 => new(TipoReporte.Diario,
                    DateTime.SpecifyKind(fechaDiaria.Date, DateTimeKind.Utc),
                    DateTime.SpecifyKind(fechaDiaria.Date.AddDays(1).AddTicks(-1), DateTimeKind.Utc),
                    null, null, null),
            1 => new(TipoReporte.Semanal,
                    DateTime.SpecifyKind(semanaDesde.Date, DateTimeKind.Utc),
                    DateTime.SpecifyKind(semanaHasta.Date.AddDays(1).AddTicks(-1), DateTimeKind.Utc),
                    null, null, null),
            2 => new(TipoReporte.Mensual,
                    DateTime.SpecifyKind(new DateTime(anio, mesSeleccionado, 1), DateTimeKind.Utc),
                    DateTime.SpecifyKind(new DateTime(anio, mesSeleccionado, 1).AddMonths(1).AddTicks(-1), DateTimeKind.Utc),
                    null, null, null),
            3 => new(TipoReporte.ComparacionAnual, null, null, anio, null, anioComparacion),
            4 => new(TipoReporte.ComparacionMensual, null, null, anio, null, null),
            _ => new(TipoReporte.Mensual, null, null, null, null, null)
        };
    }
}
