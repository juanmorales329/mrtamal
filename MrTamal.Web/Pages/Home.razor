@page "/"
@attribute [Authorize]
@inject ApiService Api
@inject AuthService AuthSvc
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<PageTitle>Inicio - MrTamal</PageTitle>

<style>
    .home-kpi { border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,.08); background:white; padding:1rem 1.2rem; }
    .home-kpi .lbl { font-size:.72rem; text-transform:uppercase; letter-spacing:.05em; color:#888; margin-bottom:.2rem; }
    .home-kpi .val { font-size:1.6rem; font-weight:800; line-height:1.1; }
    .home-kpi .sub { font-size:.78rem; margin-top:.25rem; }
    .trend-up { color:#4CAF50; } .trend-down { color:#F44336; } .trend-eq { color:#9E9E9E; }
    .alerta-meta { background:linear-gradient(135deg,#FFF3E0,#FFE0B2); border-left:4px solid #FF6D00; border-radius:10px; padding:.9rem 1.1rem; }
    .section-title { font-size:.8rem; text-transform:uppercase; letter-spacing:.08em; color:#888; font-weight:700; margin-bottom:.6rem; }
    .mov-row { display:flex; justify-content:space-between; align-items:center; padding:.45rem 0; border-bottom:1px solid #f5f5f5; font-size:.88rem; }
    .mov-row:last-child { border-bottom:none; }
</style>

@if (cargando)
{
    <div class="text-center py-5 text-muted">Cargando...</div>
}
else
{
    <!-- Alerta días sin actualizar -->
    @if (diasSinActualizar > 0)
    {
        var alertColor = diasSinActualizar >= 7 ? "#C62828" : diasSinActualizar >= 3 ? "#E65100" : "#F57F17";
        var alertBg = diasSinActualizar >= 7 ? "#FFEBEE" : diasSinActualizar >= 3 ? "#FFF3E0" : "#FFFDE7";
        var emoji = diasSinActualizar >= 7 ? "🚨" : diasSinActualizar >= 3 ? "⚠️" : "📋";
        <div class="mb-4 d-flex align-items-center gap-3" style="background:@alertBg;border-left:4px solid @alertColor;border-radius:10px;padding:.9rem 1.1rem">
            <span style="font-size:1.6rem">@emoji</span>
            <div>
                <div class="fw-bold" style="color:@alertColor">
                    @(diasSinActualizar == 1 ? "1 día sin registrar ingresos" : $"{diasSinActualizar} días sin registrar ingresos")
                </div>
                <div style="font-size:.83rem;color:#555;margin-top:2px">
                    Último registro: <strong>@ultimaFechaIngreso!.Value.ToString("dddd dd/MM/yyyy")</strong>
                    — <a href="/ingresos" style="color:@alertColor;font-weight:600">Registrar ahora →</a>
                </div>
            </div>
        </div>
    }

    <!-- Alerta meta diaria -->
    @if (metaDiaria > 0 && ingresosHoy < metaDiaria * 0.7m)
    {
        <div class="alerta-meta mb-4 d-flex align-items-center gap-3">
            <span style="font-size:1.8rem">⚠️</span>
            <div>
                <div class="fw-bold" style="color:#E65100">Vas por debajo de la meta diaria</div>
                <div style="font-size:.85rem;color:#BF360C">
                    Llevas @simbolo @ingresosHoy.ToString("N2") de @simbolo @metaDiaria.ToString("N2") meta
                    (@Math.Round(metaDiaria > 0 ? ingresosHoy / metaDiaria * 100 : 0, 1)%)
                </div>
            </div>
        </div>
    }

    <!-- KPIs del día -->
    <div class="mb-2"><span class="section-title">📅 Hoy — @DateTime.Today.ToString("dddd dd/MM/yyyy")</span></div>
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="home-kpi" style="border-left:4px solid #4CAF50">
                <div class="lbl">Ingresos hoy</div>
                <div class="val text-success">@simbolo @ingresosHoy.ToString("N2")</div>
                <div class="sub @TrendClass(ingresosHoy, ingresosAyer)">
                    @TrendIcon(ingresosHoy, ingresosAyer) vs ayer @simbolo @ingresosAyer.ToString("N2")
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="home-kpi" style="border-left:4px solid #F44336">
                <div class="lbl">Egresos hoy</div>
                <div class="val text-danger">@simbolo @egresosHoy.ToString("N2")</div>
                <div class="sub @TrendClass(egresosAyer, egresosHoy)">
                    @TrendIcon(egresosAyer, egresosHoy) vs ayer @simbolo @egresosAyer.ToString("N2")
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="home-kpi" style="border-left:4px solid #2196F3">
                <div class="lbl">Balance hoy</div>
                @{ var balHoy = ingresosHoy - egresosHoy; }
                <div class="val @(balHoy >= 0 ? "text-primary" : "text-warning")">@simbolo @balHoy.ToString("N2")</div>
                <div class="sub text-muted">Neto del día</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="home-kpi" style="border-left:4px solid @(metaDiaria > 0 && ingresosHoy >= metaDiaria ? "#4CAF50" : "#FF6D00")">
                <div class="lbl">Meta diaria</div>
                <div class="val" style="color:@(metaDiaria > 0 && ingresosHoy >= metaDiaria ? "#4CAF50" : "#FF6D00")">
                    @(metaDiaria > 0 ? $"{Math.Round(metaDiaria > 0 ? ingresosHoy / metaDiaria * 100 : 0, 1)}%" : "—")
                </div>
                <div class="sub text-muted">@(metaDiaria > 0 ? $"Meta: {simbolo} {metaDiaria:N2}" : "Sin meta configurada")</div>
            </div>
        </div>
    </div>

    <!-- KPIs del mes -->
    <div class="mb-2"><span class="section-title">🗓 @DateTime.Today.ToString("MMMM yyyy")</span></div>
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
            <div class="home-kpi" style="border-left:4px solid #4CAF50">
                <div class="lbl">Ingresos del mes</div>
                <div class="val text-success">@simbolo @(resumenMes?.TotalIngresos.ToString("N2") ?? "0.00")</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="home-kpi" style="border-left:4px solid #F44336">
                <div class="lbl">Egresos del mes</div>
                <div class="val text-danger">@simbolo @(resumenMes?.TotalEgresos.ToString("N2") ?? "0.00")</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="home-kpi" style="border-left:4px solid #2196F3">
                <div class="lbl">Balance del mes</div>
                @{ var balMes = resumenMes?.Balance ?? 0; }
                <div class="val @(balMes >= 0 ? "text-primary" : "text-warning")">@simbolo @balMes.ToString("N2")</div>
            </div>
        </div>
    </div>

    <!-- Últimos movimientos -->
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm" style="border-radius:12px">
                <div class="card-header" style="background:#E8F5E9;color:#2E7D32;border-radius:12px 12px 0 0;font-weight:700">
                    💰 Últimos Ingresos
                </div>
                <div class="card-body p-3">
                    @if (resumenMes?.Ingresos.Any() == true)
                    {
                        @foreach (var i in resumenMes.Ingresos.TakeLast(6).Reverse())
                        {
                            <div class="mov-row">
                                <div>
                                    <span class="badge bg-secondary me-1" style="font-size:.7rem">@i.Codigo</span>
                                    <span style="color:#555">@i.Descripcion</span>
                                </div>
                                <div class="d-flex flex-column align-items-end">
                                    <span class="text-success fw-bold">@simbolo @i.Cantidad.ToString("N2")</span>
                                    <span style="font-size:.72rem;color:#aaa">@i.Fecha.ToString("dd/MM")</span>
                                </div>
                            </div>
                        }
                    }
                    else { <p class="text-muted small mb-0">Sin ingresos este mes</p> }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm" style="border-radius:12px">
                <div class="card-header" style="background:#FFEBEE;color:#C62828;border-radius:12px 12px 0 0;font-weight:700">
                    💸 Últimos Egresos
                </div>
                <div class="card-body p-3">
                    @if (resumenMes?.Egresos.Any() == true)
                    {
                        @foreach (var e in resumenMes.Egresos.TakeLast(6).Reverse())
                        {
                            <div class="mov-row">
                                <div>
                                    <span class="badge bg-secondary me-1" style="font-size:.7rem">@e.Codigo</span>
                                    <span style="color:#555">@e.Descripcion</span>
                                </div>
                                <div class="d-flex flex-column align-items-end">
                                    <span class="text-danger fw-bold">@simbolo @e.Cantidad.ToString("N2")</span>
                                    <span style="font-size:.72rem;color:#aaa">@e.Fecha.ToString("dd/MM")</span>
                                </div>
                            </div>
                        }
                    }
                    else { <p class="text-muted small mb-0">Sin egresos este mes</p> }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool cargando = true;
    private string simbolo = "$";
    private decimal ingresosHoy, egresosHoy, ingresosAyer, egresosAyer, metaDiaria;
    private ReporteResumen? resumenMes;
    private DateTime? ultimaFechaIngreso;
    private int diasSinActualizar;

    protected override async Task OnInitializedAsync()
    {
        simbolo = await AuthSvc.GetSimboloMonedaAsync();

        var hoy = DateTime.Today;
        var ayer = hoy.AddDays(-1);

        // Cargar en paralelo
        var taskMes = Api.GetReporteAsync(new(TipoReporte.Mensual,
            new DateTime(hoy.Year, hoy.Month, 1, 0, 0, 0, DateTimeKind.Utc),
            new DateTime(hoy.Year, hoy.Month, 1, 0, 0, 0, DateTimeKind.Utc).AddMonths(1).AddMilliseconds(-1),
            hoy.Year, hoy.Month, null));
        var taskHoy = Api.GetReporteAsync(new(TipoReporte.Diario,
            new DateTime(hoy.Year, hoy.Month, hoy.Day, 0, 0, 0, DateTimeKind.Utc),
            new DateTime(hoy.Year, hoy.Month, hoy.Day, 23, 59, 59, 999, DateTimeKind.Utc),
            null, null, null));
        var taskAyer = Api.GetReporteAsync(new(TipoReporte.Diario,
            new DateTime(ayer.Year, ayer.Month, ayer.Day, 0, 0, 0, DateTimeKind.Utc),
            new DateTime(ayer.Year, ayer.Month, ayer.Day, 23, 59, 59, 999, DateTimeKind.Utc),
            null, null, null));
        var taskUltima = Api.GetUltimaFechaIngresoAsync();

        await Task.WhenAll(taskMes, taskHoy, taskAyer, taskUltima);

        resumenMes = taskMes.Result;
        ingresosHoy = taskHoy.Result?.TotalIngresos ?? 0;
        egresosHoy = taskHoy.Result?.TotalEgresos ?? 0;
        ingresosAyer = taskAyer.Result?.TotalIngresos ?? 0;
        egresosAyer = taskAyer.Result?.TotalEgresos ?? 0;
        ultimaFechaIngreso = taskUltima.Result?.Date;

        if (ultimaFechaIngreso.HasValue)
            diasSinActualizar = (hoy.AddDays(-1) - ultimaFechaIngreso.Value.Date).Days;

        // Obtener meta diaria del proyectado
        try
        {
            var token = await localStorage.GetItemAsync<string>("authToken");
            var sucursalId = await localStorage.GetItemAsync<string>("sucursalActivaId");

            // Intentar año actual, si no hay meta intentar año anterior
            foreach (var anio in new[] { hoy.Year, hoy.Year - 1 })
            {
                using var req = new HttpRequestMessage(HttpMethod.Get,
                    $"https://mrtamal.onrender.com/api/proyectado/{anio}");
                req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token ?? "");
                if (!string.IsNullOrEmpty(sucursalId))
                    req.Headers.Add("X-Sucursal-Id", sucursalId);
                var resp = await Http.SendAsync(req);
                if (resp.IsSuccessStatusCode)
                {
                    var proy = await resp.Content.ReadFromJsonAsync<ResumenProyectado>();
                    metaDiaria = proy?.MetaDiaria ?? 0;
                    break;
                }
            }
        }
        catch { }

        cargando = false;
    }

    private string TrendClass(decimal actual, decimal anterior) =>
        actual > anterior ? "trend-up" : actual < anterior ? "trend-down" : "trend-eq";

    private string TrendIcon(decimal actual, decimal anterior) =>
        actual > anterior ? "▲" : actual < anterior ? "▼" : "—";
}
