@page "/catalogos"
@attribute [Authorize]
@inject ApiService Api

<PageTitle>Catálogos</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">📋 Catálogos de Tipos</h3>
    <button class="btn btn-primary" @onclick="() => AbrirModal(null)">+ Nuevo</button>
</div>

@if (lista is null)
{
    <p class="text-muted">Cargando...</p>
}
else
{
    var ingresos = lista.Where(c => c.Tipo == TipoCatalogo.Ingreso).ToList();
    var egresos  = lista.Where(c => c.Tipo == TipoCatalogo.Egreso).ToList();

    <!-- Ingresos -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius:12px;overflow:hidden">
        <div class="card-header d-flex justify-content-between align-items-center"
             style="background:#E8F5E9;color:#2E7D32;font-weight:700;font-size:.95rem">
            <span>💰 Ingresos <span class="badge ms-2" style="background:#2E7D32">@ingresos.Count</span></span>
            <button class="btn btn-sm" style="background:#2E7D32;color:white;border-radius:6px"
                    @onclick="() => AbrirModalTipo(1)">+ Agregar</button>
        </div>
        <div class="card-body p-0">
            @if (!ingresos.Any())
            {
                <p class="text-muted text-center py-3 mb-0" style="font-size:.88rem">Sin tipos de ingreso</p>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead style="background:#f9f9f9">
                        <tr>
                            <th style="width:90px;font-size:.78rem;color:#666">Código</th>
                            <th style="font-size:.78rem;color:#666">Descripción</th>
                            <th style="width:90px;font-size:.78rem;color:#666">Estado</th>
                            <th style="width:70px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in ingresos.OrderBy(x => x.Codigo))
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@c.Codigo</span></td>
                                <td class="fw-semibold">@c.Descripcion</td>
                                <td>
                                    <span class="badge @(c.Activo ? "bg-success" : "bg-danger")" style="font-size:.72rem">
                                        @(c.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" style="font-size:.75rem;padding:2px 8px"
                                            @onclick="() => AbrirModal(c)">✏ Editar</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Egresos -->
    <div class="card border-0 shadow-sm" style="border-radius:12px;overflow:hidden">
        <div class="card-header d-flex justify-content-between align-items-center"
             style="background:#FFEBEE;color:#C62828;font-weight:700;font-size:.95rem">
            <span>💸 Egresos <span class="badge ms-2" style="background:#C62828">@egresos.Count</span></span>
            <button class="btn btn-sm" style="background:#C62828;color:white;border-radius:6px"
                    @onclick="() => AbrirModalTipo(2)">+ Agregar</button>
        </div>
        <div class="card-body p-0">
            @if (!egresos.Any())
            {
                <p class="text-muted text-center py-3 mb-0" style="font-size:.88rem">Sin tipos de egreso</p>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead style="background:#f9f9f9">
                        <tr>
                            <th style="width:90px;font-size:.78rem;color:#666">Código</th>
                            <th style="font-size:.78rem;color:#666">Descripción</th>
                            <th style="width:90px;font-size:.78rem;color:#666">Estado</th>
                            <th style="width:70px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in egresos.OrderBy(x => x.Codigo))
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@c.Codigo</span></td>
                                <td class="fw-semibold">@c.Descripcion</td>
                                <td>
                                    <span class="badge @(c.Activo ? "bg-success" : "bg-danger")" style="font-size:.72rem">
                                        @(c.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" style="font-size:.75rem;padding:2px 8px"
                                            @onclick="() => AbrirModal(c)">✏ Editar</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@if (mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;overflow:hidden">
                <div class="modal-header" style="background:@(formTipo == 1 ? "#E8F5E9" : "#FFEBEE");color:@(formTipo == 1 ? "#2E7D32" : "#C62828")">
                    <h5 class="modal-title fw-bold">
                        @(editando?.Id > 0 ? "✏ Editar" : "+ Nuevo") @(formTipo == 1 ? "Ingreso" : "Egreso")
                    </h5>
                    <button class="btn-close" @onclick="() => mostrarModal = false"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="alert alert-danger py-2 small">@error</div>
                    }
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Código</label>
                        <input class="form-control" @bind="formCodigo" placeholder="Ej: 1007, 2011" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Descripción</label>
                        <input class="form-control" @bind="formDescripcion" placeholder="Ej: Ventas en línea" />
                    </div>
                    @if (editando?.Id == 0)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tipo</label>
                            <select class="form-select" @bind="formTipo" @bind:after="ActualizarCodigoSugerido">
                                <option value="1">💰 Ingreso</option>
                                <option value="2">💸 Egreso</option>
                            </select>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Estado</label>
                            <select class="form-select" @bind="formActivo">
                                <option value="true">Activo</option>
                                <option value="false">Inactivo</option>
                            </select>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarModal = false">Cancelar</button>
                    <button class="btn text-white fw-bold" style="background:@(formTipo == 1 ? "#2E7D32" : "#C62828")"
                            @onclick="Guardar">💾 Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CatalogoDto>? lista;
    private bool mostrarModal;
    private CatalogoDto? editando;
    private string formCodigo = "", formDescripcion = "";
    private int formTipo = 1;
    private bool formActivo = true;
    private string? error;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar() => lista = await Api.GetCatalogosAsync();

    private async Task AbrirModal(CatalogoDto? cat)
    {
        editando = cat ?? new(0, "", "", TipoCatalogo.Ingreso, true);
        formCodigo = editando.Codigo;
        formDescripcion = editando.Descripcion;
        formTipo = (int)editando.Tipo;
        formActivo = editando.Activo;
        error = null;
        if (editando.Id == 0)
            formCodigo = await Api.GetSiguienteCodigoAsync((TipoCatalogo)formTipo) ?? "";
        mostrarModal = true;
    }

    private async Task AbrirModalTipo(int tipo)
    {
        formTipo = tipo;
        await AbrirModal(null);
    }

    private async Task ActualizarCodigoSugerido()
    {
        if (editando?.Id == 0)
            formCodigo = await Api.GetSiguienteCodigoAsync((TipoCatalogo)formTipo) ?? "";
    }

    private async Task Guardar()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(formCodigo) || string.IsNullOrWhiteSpace(formDescripcion))
        { error = "Código y descripción son requeridos."; return; }
        try
        {
            if (editando?.Id == 0)
            {
                var r = await Api.CreateCatalogoAsync(new(formCodigo, formDescripcion, (TipoCatalogo)formTipo));
                if (r is null) { error = "Error al guardar."; return; }
            }
            else
            {
                var r = await Api.UpdateCatalogoAsync(editando!.Id, new(formCodigo, formDescripcion, formActivo));
                if (r is null) { error = "Error al actualizar."; return; }
            }
            mostrarModal = false;
            await Cargar();
        }
        catch (Exception ex)
        {
            error = ex.Message.Contains("ya existe") ? ex.Message : "Error de conexión.";
        }
    }
}
