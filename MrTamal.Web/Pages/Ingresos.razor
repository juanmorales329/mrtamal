@page "/ingresos"
@attribute [Authorize(Roles = "Admin,Gerente,Contador,Usuario")]
@inject ApiService Api
@inject AuthService AuthSvc

<PageTitle>Ingresos</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="text-success mb-0">💰 Ingresos</h3>
    <button class="btn btn-success" @onclick="() => AbrirModal(null)">+ Nuevo Ingreso</button>
</div>

<!-- Navegación por mes -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <button class="btn btn-sm btn-outline-secondary" @onclick="MesAnterior">◀</button>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm" style="width:130px" @bind="mesActual" @bind:after="Cargar">
                    @for (int m = 1; m <= 12; m++)
                    {
                        var mes = m;
                        var nombre = new DateTime(2000, mes, 1).ToString("MMMM");
                        <option value="@mes">@nombre</option>
                    }
                </select>
                <select class="form-select form-select-sm" style="width:90px" @bind="anioActual" @bind:after="Cargar">
                    @for (int a = DateTime.Now.Year + 1; a >= DateTime.Now.Year - 5; a--)
                    {
                        <option value="@a">@a</option>
                    }
                </select>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="MesSiguiente">▶</button>
            <span class="badge bg-success fs-6">@mesAnioTexto</span>
            <button class="btn btn-sm btn-outline-primary ms-auto" @onclick="IrHoy">Hoy</button>
        </div>
    </div>
</div>

@if (lista is null)
{
    <p>Cargando...</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-success">
                <tr><th>Fecha</th><th>Código</th><th>Descripción</th><th>Cantidad</th><th>Total del día</th><th>Notas</th><th></th></tr>
            </thead>
            <tbody>
                @{
                    var grupos = lista.GroupBy(i => i.Fecha.Date).OrderByDescending(g => g.Key);
                    foreach (var grupo in grupos)
                    {
                        var totalDia = grupo.Sum(i => i.Cantidad);
                        var esPrimero = true;
                        foreach (var i in grupo.OrderByDescending(x => x.Id))
                        {
                            <tr>
                                <td>@i.Fecha.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-secondary">@i.CodigoCatalogo</span></td>
                                <td>@i.DescripcionCatalogo</td>
                                <td class="text-success fw-bold">@simbolo @i.Cantidad.ToString("N2")</td>
                                @if (esPrimero)
                                {
                                    <td rowspan="@grupo.Count()" class="align-middle text-center fw-bold text-success bg-success bg-opacity-10">
                                        @simbolo @totalDia.ToString("N2")
                                    </td>
                                    esPrimero = false;
                                }
                                <td class="text-muted small">@i.Notas</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirModal(i)">✏</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(i.Id)">🗑</button>
                                </td>
                            </tr>
                        }
                    }
                }
                @if (!lista.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Sin ingresos en este mes</td></tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-success">
                    <td colspan="3"><strong>Total @mesAnioTexto</strong></td>
                    <td><strong>@simbolo @lista.Sum(i => i.Cantidad).ToString("N2")</strong></td>
                    <td colspan="3"></td>
                </tr>
            </tfoot>
        </table>
    </div>
}

@if (mostrarModal)
{
    <MovimientoModal Titulo="@(editandoId > 0 ? "Editar Ingreso" : "Nuevo Ingreso")"
                     Catalogos="catalogosDisponibles"
                     Fecha="@formFecha"
                     CatalogoId="@formCatalogoId"
                     Cantidad="@formCantidad"
                     Notas="@formNotas"
                     OnGuardar="Guardar"
                     OnCancelar="() => mostrarModal = false"
                     FechaChanged="OnFormFechaChanged"
                     CatalogoIdChanged="v => formCatalogoId = v"
                     CantidadChanged="v => formCantidad = v"
                     NotasChanged="v => formNotas = v" />
}

@code {
    private List<MovimientoDto>? lista;
    private List<CatalogoDto>? catalogos;
    private List<CatalogoDto>? catalogosDisponibles;
    private int mesActual = DateTime.Now.Month;
    private int anioActual = DateTime.Now.Year;
    private bool mostrarModal;
    private int editandoId;
    private DateTime formFecha = DateTime.Today;
    private int formCatalogoId;
    private decimal formCantidad;
    private string? formNotas;
    private string simbolo = "$";

    private string mesAnioTexto => new DateTime(anioActual, mesActual, 1).ToString("MMMM yyyy");

    protected override async Task OnInitializedAsync()
    {
        simbolo = await AuthSvc.GetSimboloMonedaAsync();
        catalogos = await Api.GetCatalogosAsync(TipoCatalogo.Ingreso);
        await Cargar();
    }

    private async Task Cargar()
    {
        var desde = new DateTime(anioActual, mesActual, 1);
        var hasta = desde.AddMonths(1).AddDays(-1);
        lista = await Api.GetIngresosAsync(desde, hasta);
    }

    private async Task MesAnterior()
    {
        if (mesActual == 1) { mesActual = 12; anioActual--; }
        else mesActual--;
        await Cargar();
    }

    private async Task MesSiguiente()
    {
        if (mesActual == 12) { mesActual = 1; anioActual++; }
        else mesActual++;
        await Cargar();
    }

    private async Task IrHoy()
    {
        mesActual = DateTime.Now.Month;
        anioActual = DateTime.Now.Year;
        await Cargar();
    }

    private void AbrirModal(MovimientoDto? m)
    {
        editandoId = m?.Id ?? 0;
        formFecha = m?.Fecha ?? DateTime.Today;
        formCatalogoId = catalogos?.FirstOrDefault()?.Id ?? 0;
        formCantidad = m?.Cantidad ?? 0;
        formNotas = m?.Notas;
        mostrarModal = true;
        ActualizarCatalogosDisponibles();
    }

    private void ActualizarCatalogosDisponibles()
    {
        if (editandoId > 0 || lista is null || catalogos is null)
        {
            catalogosDisponibles = catalogos;
            return;
        }
        var usadosEnFecha = lista
            .Where(i => i.Fecha.Date == formFecha.Date)
            .Select(i => i.CodigoCatalogo)
            .ToHashSet();
        catalogosDisponibles = catalogos.Where(c => !usadosEnFecha.Contains(c.Codigo)).ToList();
        formCatalogoId = catalogosDisponibles?.FirstOrDefault()?.Id ?? 0;
    }

    private void OnFormFechaChanged(DateTime fecha)
    {
        formFecha = fecha;
        ActualizarCatalogosDisponibles();
    }

    private async Task Guardar()
    {
        try
        {
            if (editandoId > 0)
                await Api.UpdateIngresoAsync(editandoId, new(formFecha, formCatalogoId, formCantidad, formNotas));
            else
                await Api.CreateIngresoAsync(new(formFecha, formCatalogoId, formCantidad, formNotas));
            mostrarModal = false;
            await Cargar();
        }
        catch { }
    }

    private async Task Eliminar(int id)
    {
        await Api.DeleteIngresoAsync(id);
        await Cargar();
    }
}
