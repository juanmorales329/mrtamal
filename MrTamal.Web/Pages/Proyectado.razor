@page "/proyectado"
@attribute [Authorize]
@inject HttpClient Http
@inject AuthService AuthSvc
@inject IJSRuntime JS
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<PageTitle>Proyectado de Ventas</PageTitle>

<style>
    .proy-header { background: linear-gradient(135deg, #FF6D00, #FF8F00); color: white; border-radius: 12px; padding: 1.2rem 1.5rem; margin-bottom: 1.5rem; }
    .proy-card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); margin-bottom: 1.25rem; overflow: hidden; }
    .proy-card .card-header { font-weight: 700; font-size: .95rem; padding: .75rem 1.1rem; border-bottom: 1px solid rgba(0,0,0,.08); }
    .kpi-card { border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); padding: 1rem 1.2rem; text-align: center; background: white; }
    .kpi-card .kpi-label { font-size: .75rem; color: #888; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .25rem; }
    .kpi-card .kpi-value { font-size: 1.5rem; font-weight: 800; line-height: 1.1; }
    .proy-table { width: 100%; border-collapse: collapse; table-layout: auto; }
    .proy-table th { background: #f5f5f5; font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; color: #555; padding: .6rem .9rem; border-bottom: 2px solid #e0e0e0; white-space: nowrap; }
    .proy-table td { padding: .65rem .9rem; border-bottom: 1px solid #f0f0f0; font-size: .88rem; vertical-align: middle; }
    .proy-table tr:last-child td { border-bottom: none; }
    .proy-table tr:hover td { background: #fafafa; }
    .mes-row td { background: #FFF8F0 !important; font-size: .84rem; }
    .mes-row td:first-child { padding-left: 2rem; }
    .mes-row:hover td { background: #FFF3E0 !important; }
    .progress-wrap { display: flex; align-items: center; gap: 8px; min-width: 120px; }
    .progress-bar-bg { flex: 1; height: 8px; background: #e0e0e0; border-radius: 4px; overflow: hidden; min-width: 60px; }
    .progress-bar-fill { height: 100%; border-radius: 4px; transition: width .4s; }
    .btn-expand { border: 1px solid #ddd; background: white; border-radius: 6px; padding: 3px 10px; font-size: .78rem; cursor: pointer; white-space: nowrap; color: #555; }
    .btn-expand:hover { background: #f5f5f5; }
    .proy-chart-wrap { position: relative; width: 100%; }
    @@media (max-width: 768px) {
        .proy-table th, .proy-table td { padding: .5rem .6rem; font-size: .8rem; }
        .kpi-card .kpi-value { font-size: 1.2rem; }
        .hide-mobile { display: none !important; }
        .mes-row td:first-child { padding-left: 1.2rem; }
    }
    @@media (max-width: 480px) {
        .proy-table th, .proy-table td { padding: .4rem .45rem; font-size: .75rem; }
        .progress-wrap { min-width: 80px; }
    }
</style>

<!-- Header -->
<div class="proy-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <div style="font-size:1.4rem;font-weight:800">🎯 Proyectado de Ventas</div>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
        <button class="btn btn-sm btn-light fw-semibold" @onclick="() => mostrarConfigMeta = true" title="Configurar meta">
            ⚙ Meta
        </button>
        @if (resumen is not null)
        {
            <button class="btn btn-sm btn-light fw-semibold" @onclick="DescargarPdf" disabled="@descargando">
                @(descargando ? "⏳" : "📄 PDF")
            </button>
            <button class="btn btn-sm btn-light fw-semibold" @onclick="DescargarExcel" disabled="@descargandoExcel">
                @(descargandoExcel ? "⏳" : "📊 Excel")
            </button>
        }
        <select class="form-select form-select-sm" style="width:100px;border-radius:8px" @bind="anioSeleccionado" @bind:after="Cargar">
            @for (int a = DateTime.Now.Year; a >= DateTime.Now.Year - 5; a--)
            {
                <option value="@a">@a</option>
            }
        </select>
    </div>
</div>

@if (mostrarConfigMeta)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;overflow:hidden">
                <div class="modal-header text-white" style="background:#FF6D00">
                    <h5 class="modal-title">⚙ Configurar Meta Anual @anioSeleccionado</h5>
                    <button class="btn-close btn-close-white" @onclick="() => mostrarConfigMeta = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Meta de Ventas Anual (@simbolo)</label>
                        <input type="number" class="form-control" @bind="formMeta" step="100" />
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="formExcluirDomingos" id="domCheck" />
                        <label class="form-check-label fw-semibold" for="domCheck">Excluir todos los domingos</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarConfigMeta = false">Cancelar</button>
                    <button class="btn text-white fw-bold" style="background:#FF6D00" @onclick="GuardarMetaYCerrar">💾 Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (resumen is not null)
{
    <!-- KPIs compactos con meta -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="kpi-card" style="border-left:4px solid #FF6D00">
                <div class="kpi-label">Meta Anual</div>
                <div class="kpi-value" style="color:#FF6D00">@simbolo @resumen.MetaAnual.ToString("N0")</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card" style="border-left:4px solid #4CAF50">
                <div class="kpi-label">Venta Real</div>
                <div class="kpi-value text-success">@simbolo @resumen.VentaReal.ToString("N0")</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card" style="border-left:4px solid #2196F3">
                <div class="kpi-label">Días Laborables</div>
                <div class="kpi-value text-primary">@resumen.DiasLaborables</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            @{ var pctAnual = resumen.PorcentajeCumplimiento; var colorAnual = pctAnual >= 100 ? "#4CAF50" : pctAnual >= 70 ? "#FF9800" : "#F44336"; }
            <div class="kpi-card" style="border-left:4px solid @colorAnual">
                <div class="kpi-label">Cumplimiento</div>
                <div class="kpi-value" style="color:@colorAnual">@pctAnual%</div>
            </div>
        </div>
    </div>

    <!-- Cuatrimestres -->
    @if (resumen.Cuatrimestres?.Any() == true)
    {
        <div class="proy-card card">
            <div class="card-header text-white" style="background:#FF6D00">
                🎯 Control por Cuatrimestre &nbsp;<span style="font-weight:400;font-size:.82rem;opacity:.9">(Meta: @simbolo 100,000 c/u)</span>
            </div>
            <div style="overflow-x:auto">
                <table class="proy-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Período</th>
                            <th>Meta</th>
                            <th>Real</th>
                            <th class="hide-mobile">Diferencia</th>
                            <th>Avance</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in resumen.Cuatrimestres)
                        {
                            var cc = c;
                            var ccolor = cc.PorcentajeCumplimiento >= 100 ? "#4CAF50" : cc.PorcentajeCumplimiento >= 70 ? "#FF9800" : "#F44336";
                            var cpct = Math.Min((double)cc.PorcentajeCumplimiento, 100);
                            var expandido = cuatrimestresExpandidos.Contains(cc.Numero);
                            var mesesC = resumen.DesgloseMensual
                                .Where(m => m.Mes >= (cc.Numero - 1) * 4 + 1 && m.Mes <= cc.Numero * 4)
                                .ToList();
                            <tr>
                                <td><span style="font-weight:700;font-size:.95rem">@cc.Numero°</span></td>
                                <td style="white-space:nowrap">@cc.Periodo</td>
                                <td style="white-space:nowrap">@simbolo @cc.Meta.ToString("N0")</td>
                                <td style="white-space:nowrap;font-weight:700;color:#2E7D32">@simbolo @cc.VentaReal.ToString("N0")</td>
                                <td class="hide-mobile" style="white-space:nowrap;font-weight:700;color:@ccolor">
                                    @(cc.Diferencia >= 0 ? "+" : "")@simbolo @cc.Diferencia.ToString("N0")
                                </td>
                                <td>
                                    <div class="progress-wrap">
                                        <div class="progress-bar-bg">
                                            <div class="progress-bar-fill" style="width:@cpct%;background:@ccolor"></div>
                                        </div>
                                        <span style="font-weight:700;font-size:.8rem;color:@ccolor;min-width:36px">@cc.PorcentajeCumplimiento%</span>
                                    </div>
                                </td>
                                <td>
                                    <button class="btn-expand" @onclick="() => ToggleCuatrimestre(cc.Numero)">
                                        @(expandido ? "▲ Contraer" : "▼ Ver meses")
                                    </button>
                                </td>
                            </tr>
                            @if (expandido)
                            {
                                @foreach (var mes in mesesC)
                                {
                                    var mcolor = mes.Diferencia >= 0 ? "#2E7D32" : "#C62828";
                                    <tr class="mes-row">
                                        <td></td>
                                        <td style="font-weight:600">@mes.NombreMes</td>
                                        <td style="white-space:nowrap">@simbolo @mes.MetaMes.ToString("N0")</td>
                                        <td style="white-space:nowrap;font-weight:600">@simbolo @mes.VentaReal.ToString("N0")</td>
                                        <td class="hide-mobile" style="white-space:nowrap;font-weight:600;color:@mcolor">
                                            @(mes.Diferencia >= 0 ? "+" : "")@simbolo @mes.Diferencia.ToString("N0")
                                        </td>
                                        <td colspan="2">
                                            @if (mes.VentaReal == 0 && mes.MetaMes > 0)
                                            { <span class="badge bg-secondary" style="font-size:.72rem">Pendiente</span> }
                                            else if (mes.Cumplido)
                                            { <span class="badge bg-success" style="font-size:.72rem">✓ Cumplido</span> }
                                            else
                                            { <span class="badge bg-danger" style="font-size:.72rem">✗ Bajo meta</span> }
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Metas por período -->
    <div class="proy-card card">
        <div class="card-header bg-dark text-white">📊 Metas por Período</div>
        <div style="overflow-x:auto">
            <table class="proy-table">
                <thead><tr><th>Período</th><th>Días</th><th>Meta (@simbolo)</th></tr></thead>
                <tbody>
                    <tr><td>📅 Diario</td><td>1</td><td style="font-weight:700">@simbolo @resumen.MetaDiaria.ToString("N2")</td></tr>
                    <tr><td>📆 Semanal</td><td>~6</td><td style="font-weight:700">@simbolo @resumen.MetaSemanal.ToString("N2")</td></tr>
                    <tr><td>🗓 Mensual</td><td>~@(resumen.DiasLaborables/12)</td><td style="font-weight:700">@simbolo @resumen.MetaMensual.ToString("N2")</td></tr>
                    <tr><td>📋 Bimestral</td><td>~@(resumen.DiasLaborables/6)</td><td style="font-weight:700">@simbolo @resumen.MetaBimestral.ToString("N2")</td></tr>
                    <tr><td>📋 Trimestral</td><td>~@(resumen.DiasLaborables/4)</td><td style="font-weight:700">@simbolo @resumen.MetaTrimestral.ToString("N2")</td></tr>
                    <tr><td>📋 Cuatrimestral</td><td>~@(resumen.DiasLaborables/3)</td><td style="font-weight:700">@simbolo @resumen.MetaCuatrimestral.ToString("N2")</td></tr>
                    <tr><td>📋 Semestral</td><td>~@(resumen.DiasLaborables/2)</td><td style="font-weight:700">@simbolo @resumen.MetaSemestral.ToString("N2")</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Gráfica -->
    <div class="proy-card card">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>📈 Proyectado vs Real</span>
            <select class="form-select form-select-sm" style="width:auto;border-radius:8px" @bind="periodoGrafica" @bind:after="ActualizarGrafica">
                <option value="mensual">Por Mes</option>
                <option value="bimestral">Bimestral</option>
                <option value="trimestral">Trimestral</option>
                <option value="cuatrimestral">Cuatrimestral</option>
                <option value="semestral">Semestral</option>
            </select>
        </div>
        <div class="card-body p-2 p-md-3" style="position:relative;height:280px">
            <canvas id="proyChart"></canvas>
        </div>
    </div>

    <!-- Desglose mensual completo -->
    <div class="proy-card card">
        <div class="card-header bg-dark text-white">📅 Desglose Mensual</div>
        <div style="overflow-x:auto">
            <table class="proy-table">
                <thead>
                    <tr><th>Mes</th><th class="hide-mobile">Días Lab.</th><th>Meta</th><th>Real</th><th class="hide-mobile">Diferencia</th><th>Estado</th></tr>
                </thead>
                <tbody>
                    @foreach (var m in resumen.DesgloseMensual)
                    {
                        var dcolor = m.Diferencia >= 0 ? "#2E7D32" : "#C62828";
                        <tr>
                            <td style="font-weight:700">@m.NombreMes</td>
                            <td class="hide-mobile">@m.DiasLaborables</td>
                            <td style="white-space:nowrap">@simbolo @m.MetaMes.ToString("N0")</td>
                            <td style="white-space:nowrap;font-weight:600">@simbolo @m.VentaReal.ToString("N0")</td>
                            <td class="hide-mobile" style="white-space:nowrap;font-weight:700;color:@dcolor">
                                @(m.Diferencia >= 0 ? "+" : "")@simbolo @m.Diferencia.ToString("N0")
                            </td>
                            <td>
                                @if (m.VentaReal == 0 && m.MetaMes > 0)
                                { <span class="badge bg-secondary" style="font-size:.72rem">Pendiente</span> }
                                else if (m.Cumplido)
                                { <span class="badge bg-success" style="font-size:.72rem">✓ Cumplido</span> }
                                else
                                { <span class="badge bg-danger" style="font-size:.72rem">✗ Bajo meta</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Días no laborables -->
    <div class="proy-card card">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <span>🚫 Días No Laborables @anioSeleccionado</span>
            <button class="btn btn-sm btn-outline-light" style="border-radius:6px" @onclick="() => mostrarAgregarDia = true">+ Agregar</button>
        </div>
        <div class="card-body">
            @if (!resumen.DiasNoLaborables.Any())
            {
                <p class="text-muted mb-0" style="font-size:.88rem">No hay días no laborables registrados.</p>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var d in resumen.DiasNoLaborables)
                    {
                        <span class="badge bg-danger d-flex align-items-center gap-1" style="font-size:.8rem;padding:5px 9px;border-radius:6px">
                            @d.Fecha.ToString("dd/MM") @(d.Descripcion is not null ? $"- {d.Descripcion}" : "")
                            <button class="btn-close btn-close-white ms-1" style="font-size:.55rem" @onclick="() => EliminarDia(d.Id)"></button>
                        </span>
                    }
                </div>
            }
        </div>
    </div>
}
else if (sinMeta)
{
    <div class="alert alert-info" style="border-radius:10px">
        No hay meta configurada para @anioSeleccionado. Ingresa la meta anual arriba y guarda.
    </div>
}

@if (mostrarAgregarDia)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;overflow:hidden">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">🚫 Agregar Día No Laborable</h5>
                    <button class="btn-close btn-close-white" @onclick="() => mostrarAgregarDia = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Fecha</label>
                        <input type="date" class="form-control" @bind="formFechaDia" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Descripción (opcional)</label>
                        <input class="form-control" @bind="formDescDia" placeholder="Ej: Navidad, Feriado nacional..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarAgregarDia = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="AgregarDia">Agregar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int anioSeleccionado = DateTime.Now.Year;
    private decimal formMeta;
    private bool formExcluirDomingos = true;
    private ResumenProyectado? resumen;
    private bool sinMeta;
    private string simbolo = "$";
    private bool mostrarAgregarDia;
    private DateTime formFechaDia = DateTime.Today;
    private string? formDescDia;
    private HashSet<int> cuatrimestresExpandidos = new();
    private bool descargando, descargandoExcel;
    private bool mostrarConfigMeta;

    private void ToggleCuatrimestre(int numero)
    {
        if (!cuatrimestresExpandidos.Remove(numero))
            cuatrimestresExpandidos.Add(numero);
    }

    private async Task GuardarMetaYCerrar()
    {
        await GuardarMeta();
        mostrarConfigMeta = false;
    }

    private static string FormatK(decimal v) =>
        v >= 1000 ? $"{v / 1000:N1}k" : v.ToString("N0");

    protected override async Task OnInitializedAsync()
    {
        simbolo = await AuthSvc.GetSimboloMonedaAsync();
        var token = await localStorage.GetItemAsync<string>("authToken");
        if (!string.IsNullOrEmpty(token))
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        await Cargar();
    }

    private async Task Cargar()
    {
        sinMeta = false; resumen = null;
        cuatrimestresExpandidos.Clear();
        var resp = await Http.GetAsync($"https://mrtamal.onrender.com/api/proyectado/{anioSeleccionado}");
        if (resp.IsSuccessStatusCode)
        {
            resumen = await resp.Content.ReadFromJsonAsync<ResumenProyectado>();
            if (resumen is not null)
            {
                formMeta = resumen.MetaAnual;
                await Task.Delay(150);
                await RenderGrafica();
            }
        }
        else sinMeta = true;
    }

    private async Task GuardarMeta()
    {
        await Http.PostAsJsonAsync("https://mrtamal.onrender.com/api/proyectado/metas",
            new { anio = anioSeleccionado, metaVentas = formMeta, excluirDomingos = formExcluirDomingos, sucursalId = (int?)null });
        await Cargar();
    }

    private async Task AgregarDia()
    {
        await Http.PostAsJsonAsync("https://mrtamal.onrender.com/api/proyectado/dias-nolaborables",
            new { fecha = formFechaDia, descripcion = formDescDia, sucursalId = (int?)null });
        mostrarAgregarDia = false;
        await Cargar();
    }

    private async Task EliminarDia(int id)
    {
        await Http.DeleteAsync($"https://mrtamal.onrender.com/api/proyectado/dias-nolaborables/{id}");
        await Cargar();
    }

    private async Task DescargarPdf()
    {
        descargando = true;
        var bytes = await Http.GetByteArrayAsync($"https://mrtamal.onrender.com/api/proyectado/{anioSeleccionado}/pdf");
        if (bytes is not null)
            await JS.InvokeVoidAsync("downloadPdf", Convert.ToBase64String(bytes), $"proyectado_{anioSeleccionado}.pdf");
        descargando = false;
    }

    private async Task DescargarExcel()
    {
        descargandoExcel = true;
        var bytes = await Http.GetByteArrayAsync($"https://mrtamal.onrender.com/api/proyectado/{anioSeleccionado}/excel");
        if (bytes is not null)
            await JS.InvokeVoidAsync("downloadFile", Convert.ToBase64String(bytes), $"proyectado_{anioSeleccionado}.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        descargandoExcel = false;
    }

    private string periodoGrafica = "mensual";
    private async Task ActualizarGrafica() => await RenderGrafica();

    private async Task RenderGrafica()
    {
        if (resumen is null) return;
        try
        {
            string[] labels; double[] metas, reales;
            switch (periodoGrafica)
            {
                case "bimestral":     (labels, metas, reales) = AgruparPeriodos(2); break;
                case "trimestral":    (labels, metas, reales) = AgruparPeriodos(3); break;
                case "cuatrimestral": (labels, metas, reales) = AgruparPeriodos(4); break;
                case "semestral":     (labels, metas, reales) = AgruparPeriodos(6); break;
                default:
                    labels = resumen.DesgloseMensual.Select(m => m.NombreMes[..3]).ToArray();
                    metas  = resumen.DesgloseMensual.Select(m => (double)m.MetaMes).ToArray();
                    reales = resumen.DesgloseMensual.Select(m => (double)m.VentaReal).ToArray();
                    break;
            }
            await JS.InvokeVoidAsync("renderProyChart", "proyChart", labels, metas, reales);
        }
        catch { }
    }

    private (string[] labels, double[] metas, double[] reales) AgruparPeriodos(int mesesPorPeriodo)
    {
        var grupos = resumen!.DesgloseMensual
            .Select((m, i) => new { m, grupo = i / mesesPorPeriodo })
            .GroupBy(x => x.grupo).ToList();
        var labels = grupos.Select(g =>
        {
            var p = g.First().m; var u = g.Last().m;
            return p.Mes == u.Mes ? p.NombreMes[..3] : $"{p.NombreMes[..3]}-{u.NombreMes[..3]}";
        }).ToArray();
        var metas  = grupos.Select(g => (double)g.Sum(x => x.m.MetaMes)).ToArray();
        var reales = grupos.Select(g => (double)g.Sum(x => x.m.VentaReal)).ToArray();
        return (labels, metas, reales);
    }
}
