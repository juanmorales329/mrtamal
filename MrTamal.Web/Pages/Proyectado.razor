@page "/proyectado"
@attribute [Authorize]
@inject HttpClient Http
@inject AuthService AuthSvc
@inject IJSRuntime JS
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<PageTitle>Proyectado de Ventas</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">🎯 Proyectado de Ventas</h3>
    <div class="d-flex gap-2">
        <select class="form-select form-select-sm" style="width:100px" @bind="anioSeleccionado" @bind:after="Cargar">
            @for (int a = DateTime.Now.Year + 1; a >= DateTime.Now.Year - 3; a--)
            {
                <option value="@a">@a</option>
            }
        </select>
    </div>
</div>

<!-- Configurar Meta -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header fw-bold" style="background:#FF6D00;color:white">⚙ Configurar Meta Anual @anioSeleccionado</div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Meta de Ventas Anual (@simbolo)</label>
                <input type="number" class="form-control" @bind="formMeta" step="100" />
            </div>
            <div class="col-md-3">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" @bind="formExcluirDomingos" id="domCheck" />
                    <label class="form-check-label fw-bold" for="domCheck">Excluir todos los domingos</label>
                </div>
            </div>
            <div class="col-md-2">
                <button class="btn w-100 text-white" style="background:#FF6D00" @onclick="GuardarMeta">
                    💾 Guardar Meta
                </button>
            </div>
        </div>
    </div>
</div>

@if (resumen is not null)
{
    <!-- Tarjetas resumen -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3" style="border-left:5px solid #FF6D00 !important">
                <div class="text-muted small">Meta Anual</div>
                <h4 style="color:#FF6D00">@simbolo @resumen.MetaAnual.ToString("N2")</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3" style="border-left:5px solid #4CAF50 !important">
                <div class="text-muted small">Venta Real</div>
                <h4 class="text-success">@simbolo @resumen.VentaReal.ToString("N2")</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3" style="border-left:5px solid #2196F3 !important">
                <div class="text-muted small">Días Laborables</div>
                <h4 class="text-primary">@resumen.DiasLaborables días</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3"
                 style="border-left:5px solid @(resumen.PorcentajeCumplimiento >= 100 ? "#4CAF50" : "#F44336") !important">
                <div class="text-muted small">Cumplimiento</div>
                <h4 class="@(resumen.PorcentajeCumplimiento >= 100 ? "text-success" : "text-danger")">
                    @resumen.PorcentajeCumplimiento%
                </h4>
            </div>
        </div>
    </div>

    <!-- Cuatrimestres fijos: 100k cada uno -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold text-white" style="background:#FF6D00">🎯 Control por Cuatrimestre (Meta: @simbolo 100,000 c/u)</div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-secondary">
                    <tr><th>Cuatrimestre</th><th>Período</th><th>Meta</th><th>Real</th><th>Diferencia</th><th>Avance</th></tr>
                </thead>
                <tbody>
                    @foreach (var c in resumen.Cuatrimestres)
                    {
                        var color = c.PorcentajeCumplimiento >= 100 ? "#4CAF50" : c.PorcentajeCumplimiento >= 70 ? "#FF9800" : "#F44336";
                        var pct = Math.Min((double)c.PorcentajeCumplimiento, 100);
                        <tr>
                            <td class="fw-bold">@c.Numero°</td>
                            <td>@c.Periodo</td>
                            <td>@simbolo @c.Meta.ToString("N2")</td>
                            <td class="text-success fw-bold">@simbolo @c.VentaReal.ToString("N2")</td>
                            <td class="@(c.Diferencia >= 0 ? "text-success" : "text-danger") fw-bold">
                                @(c.Diferencia >= 0 ? "+" : "")@simbolo @c.Diferencia.ToString("N2")
                            </td>
                            <td style="min-width:140px">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:10px">
                                        <div class="progress-bar" style="width:@pct%;background:@color"></div>
                                    </div>
                                    <small class="fw-bold" style="color:@color;white-space:nowrap">@c.PorcentajeCumplimiento%</small>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Tabla de metas por período -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold bg-dark text-white">📊 Metas por Período</div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-secondary">
                    <tr><th>Período</th><th>Días</th><th>Meta (@simbolo)</th></tr>
                </thead>
                <tbody>
                    <tr><td>📅 Diario</td><td>1</td><td class="fw-bold">@simbolo @resumen.MetaDiaria.ToString("N2")</td></tr>
                    <tr><td>📆 Semanal</td><td>~6</td><td class="fw-bold">@simbolo @resumen.MetaSemanal.ToString("N2")</td></tr>
                    <tr><td>🗓 Mensual</td><td>~@(resumen.DiasLaborables/12)</td><td class="fw-bold">@simbolo @resumen.MetaMensual.ToString("N2")</td></tr>
                    <tr><td>📋 Bimestral (2 meses)</td><td>~@(resumen.DiasLaborables/6)</td><td class="fw-bold">@simbolo @resumen.MetaBimestral.ToString("N2")</td></tr>
                    <tr><td>📋 Trimestral (3 meses)</td><td>~@(resumen.DiasLaborables/4)</td><td class="fw-bold">@simbolo @resumen.MetaTrimestral.ToString("N2")</td></tr>
                    <tr><td>📋 Cuatrimestral (4 meses)</td><td>~@(resumen.DiasLaborables/3)</td><td class="fw-bold">@simbolo @resumen.MetaCuatrimestral.ToString("N2")</td></tr>
                    <tr><td>📋 Semestral (6 meses)</td><td>~@(resumen.DiasLaborables/2)</td><td class="fw-bold">@simbolo @resumen.MetaSemestral.ToString("N2")</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Gráfica -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <span>📈 Proyectado vs Real</span>
            <select class="form-select form-select-sm w-auto" @bind="periodoGrafica" @bind:after="ActualizarGrafica">
                <option value="mensual">Por Mes</option>
                <option value="bimestral">Bimestral</option>
                <option value="trimestral">Trimestral</option>
                <option value="cuatrimestral">Cuatrimestral</option>
                <option value="semestral">Semestral</option>
            </select>
        </div>
        <div class="card-body">
            <canvas id="proyChart" height="100"></canvas>
        </div>
    </div>

    <!-- Desglose mensual -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header fw-bold bg-dark text-white">📅 Desglose Mensual</div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-secondary">
                    <tr><th>Mes</th><th>Días Lab.</th><th>Meta</th><th>Real</th><th>Diferencia</th><th>Estado</th></tr>
                </thead>
                <tbody>
                    @foreach (var m in resumen.DesgloseMensual)
                    {
                        <tr>
                            <td class="fw-bold">@m.NombreMes</td>
                            <td>@m.DiasLaborables</td>
                            <td>@simbolo @m.MetaMes.ToString("N2")</td>
                            <td>@simbolo @m.VentaReal.ToString("N2")</td>
                            <td class="@(m.Diferencia >= 0 ? "text-success" : "text-danger") fw-bold">
                                @(m.Diferencia >= 0 ? "+" : "")@simbolo @m.Diferencia.ToString("N2")
                            </td>
                            <td>
                                @if (m.VentaReal == 0 && m.MetaMes > 0)
                                {
                                    <span class="badge bg-secondary">Pendiente</span>
                                }
                                else if (m.Cumplido)
                                {
                                    <span class="badge bg-success">✓ Cumplido</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">✗ Bajo meta</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Días no laborables -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white">
            <span>🚫 Días No Laborables @anioSeleccionado</span>
            <button class="btn btn-sm btn-outline-light" @onclick="() => mostrarAgregarDia = true">+ Agregar</button>
        </div>
        <div class="card-body">
            @if (!resumen.DiasNoLaborables.Any())
            {
                <p class="text-muted mb-0">No hay días no laborables registrados.</p>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var d in resumen.DiasNoLaborables)
                    {
                        <span class="badge bg-danger d-flex align-items-center gap-1" style="font-size:0.85rem;padding:6px 10px">
                            @d.Fecha.ToString("dd/MM") @(d.Descripcion is not null ? $"- {d.Descripcion}" : "")
                            <button class="btn-close btn-close-white ms-1" style="font-size:0.6rem"
                                    @onclick="() => EliminarDia(d.Id)"></button>
                        </span>
                    }
                </div>
            }
        </div>
    </div>
}
else if (sinMeta)
{
    <div class="alert alert-info">
        No hay meta configurada para @anioSeleccionado. Ingresa la meta anual arriba y guarda.
    </div>
}

<!-- Modal agregar día no laborable -->
@if (mostrarAgregarDia)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">🚫 Agregar Día No Laborable</h5>
                    <button class="btn-close btn-close-white" @onclick="() => mostrarAgregarDia = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Fecha</label>
                        <input type="date" class="form-control" @bind="formFechaDia" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción (opcional)</label>
                        <input class="form-control" @bind="formDescDia" placeholder="Ej: Navidad, Feriado nacional..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => mostrarAgregarDia = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="AgregarDia">Agregar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int anioSeleccionado = DateTime.Now.Year;
    private decimal formMeta;
    private bool formExcluirDomingos = true;
    private ResumenProyectado? resumen;
    private bool sinMeta;
    private string simbolo = "$";
    private bool mostrarAgregarDia;
    private DateTime formFechaDia = DateTime.Today;
    private string? formDescDia;

    protected override async Task OnInitializedAsync()
    {
        simbolo = await AuthSvc.GetSimboloMonedaAsync();
        // Asegurar que el token esté en el header
        var token = await localStorage.GetItemAsync<string>("authToken");
        if (!string.IsNullOrEmpty(token))
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        await Cargar();
    }

    private async Task Cargar()
    {
        sinMeta = false; resumen = null;
        var resp = await Http.GetAsync($"https://mrtamal.onrender.com/api/proyectado/{anioSeleccionado}");
        if (resp.IsSuccessStatusCode)
        {
            resumen = await resp.Content.ReadFromJsonAsync<ResumenProyectado>();
            if (resumen is not null)
            {
                formMeta = resumen.MetaAnual;
                await Task.Delay(150);
                await RenderGrafica();
            }
        }
        else sinMeta = true;
    }

    private async Task GuardarMeta()
    {
        await Http.PostAsJsonAsync("https://mrtamal.onrender.com/api/proyectado/metas",
            new { anio = anioSeleccionado, metaVentas = formMeta, excluirDomingos = formExcluirDomingos, sucursalId = (int?)null });
        await Cargar();
    }

    private async Task AgregarDia()
    {
        await Http.PostAsJsonAsync("https://mrtamal.onrender.com/api/proyectado/dias-nolaborables",
            new { fecha = formFechaDia, descripcion = formDescDia, sucursalId = (int?)null });
        mostrarAgregarDia = false;
        await Cargar();
    }

    private async Task EliminarDia(int id)
    {
        await Http.DeleteAsync($"https://mrtamal.onrender.com/api/proyectado/dias-nolaborables/{id}");
        await Cargar();
    }

    private string periodoGrafica = "mensual";

    private async Task ActualizarGrafica() => await RenderGrafica();

    private async Task RenderGrafica()
    {
        if (resumen is null) return;
        try
        {
            string[] labels;
            double[] metas, reales;

            switch (periodoGrafica)
            {
                case "bimestral":
                    (labels, metas, reales) = AgruparPeriodos(2);
                    break;
                case "trimestral":
                    (labels, metas, reales) = AgruparPeriodos(3);
                    break;
                case "cuatrimestral":
                    (labels, metas, reales) = AgruparPeriodos(4);
                    break;
                case "semestral":
                    (labels, metas, reales) = AgruparPeriodos(6);
                    break;
                default: // mensual
                    labels = resumen.DesgloseMensual.Select(m => m.NombreMes[..3]).ToArray();
                    metas = resumen.DesgloseMensual.Select(m => (double)m.MetaMes).ToArray();
                    reales = resumen.DesgloseMensual.Select(m => (double)m.VentaReal).ToArray();
                    break;
            }

            await JS.InvokeVoidAsync("renderProyChart", "proyChart", labels, metas, reales);
        }
        catch { }
    }

    private (string[] labels, double[] metas, double[] reales) AgruparPeriodos(int mesesPorPeriodo)
    {
        var grupos = resumen!.DesgloseMensual
            .Select((m, i) => new { m, grupo = i / mesesPorPeriodo })
            .GroupBy(x => x.grupo)
            .ToList();

        var labels = grupos.Select(g =>
        {
            var primero = g.First().m;
            var ultimo = g.Last().m;
            return primero.Mes == ultimo.Mes
                ? primero.NombreMes[..3]
                : $"{primero.NombreMes[..3]}-{ultimo.NombreMes[..3]}";
        }).ToArray();

        var metas = grupos.Select(g => (double)g.Sum(x => x.m.MetaMes)).ToArray();
        var reales = grupos.Select(g => (double)g.Sum(x => x.m.VentaReal)).ToArray();

        return (labels, metas, reales);
    }
}
