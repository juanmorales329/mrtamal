@using MrTamal.Shared.DTOs
@using System.Globalization

<div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Titulo</h5>
                <button class="btn-close" @onclick="OnCancelar"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Fecha</label>
                    <input type="date" class="form-control" value="@Fecha.ToString("yyyy-MM-dd")"
                           @onchange="e => FechaChanged.InvokeAsync(DateTime.Parse(e.Value!.ToString()!))" />
                </div>

                @if (TotalAcumuladoDia > 0)
                {
                    <div class="alert py-2 mb-3" style="background:#E8F5E9;border-left:4px solid #4CAF50;border-radius:8px">
                        <div class="d-flex align-items-center gap-2">
                            <span>📊</span>
                            <div>
                                <div class="fw-bold" style="font-size:.85rem;color:#2E7D32">Acumulado del @Fecha.ToString("dd/MM/yyyy")</div>
                                <div style="font-size:1.1rem;font-weight:800;color:#1B5E20">@Simbolo @TotalAcumuladoDia.ToString("N2")</div>
                            </div>
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Tipo</label>
                    @if (Catalogos is not null && !Catalogos.Any(c => c.Activo))
                    {
                        <div class="alert alert-warning py-2 mb-0">
                            ⚠️ Ya registraste todos los tipos disponibles para esta fecha.
                        </div>
                    }
                    else
                    {
                        <select class="form-select" value="@CatalogoId"
                                @onchange="e => CatalogoIdChanged.InvokeAsync(int.Parse(e.Value!.ToString()!))">
                            @if (Catalogos is not null)
                            {
                                @foreach (var c in Catalogos.Where(c => c.Activo))
                                {
                                    <option value="@c.Id">[@c.Codigo] @c.Descripcion</option>
                                }
                            }
                        </select>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label">Cantidad</label>
                    @if (!string.IsNullOrEmpty(errorCantidad))
                    {
                        <div class="text-danger small">@errorCantidad</div>
                    }
                    <input type="text" class="form-control @(string.IsNullOrEmpty(errorCantidad) ? "" : "is-invalid")"
                           inputmode="decimal"
                           value="@cantidadTexto"
                           placeholder="0.00"
                           @onchange="OnCantidadChange" />
                    <div class="form-text">Usa punto (.) como decimal. Ej: 620.57</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Notas (opcional)</label>
                    <input class="form-control" value="@Notas"
                           @onchange="e => NotasChanged.InvokeAsync(e.Value?.ToString())" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="OnCancelar">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleGuardar"
                        disabled="@(guardando || !string.IsNullOrEmpty(errorCantidad) || SinTiposDisponibles)">
                    @(guardando ? "⏳ Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Titulo { get; set; } = "";
    [Parameter] public List<CatalogoDto>? Catalogos { get; set; }
    [Parameter] public DateTime Fecha { get; set; }
    [Parameter] public int CatalogoId { get; set; }
    [Parameter] public decimal Cantidad { get; set; }
    [Parameter] public string? Notas { get; set; }
    [Parameter] public decimal TotalAcumuladoDia { get; set; }
    [Parameter] public string Simbolo { get; set; } = "$";
    [Parameter] public EventCallback OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }
    [Parameter] public EventCallback<DateTime> FechaChanged { get; set; }
    [Parameter] public EventCallback<int> CatalogoIdChanged { get; set; }
    [Parameter] public EventCallback<decimal> CantidadChanged { get; set; }
    [Parameter] public EventCallback<string?> NotasChanged { get; set; }

    private string cantidadTexto = "";
    private string errorCantidad = "";
    private bool guardando = false;

    private bool SinTiposDisponibles => Catalogos is not null && !Catalogos.Any(c => c.Activo);

    private async Task HandleGuardar()
    {
        if (guardando) return;
        guardando = true;
        await OnGuardar.InvokeAsync();
        guardando = false;
    }

    protected override void OnParametersSet()
    {
        // Mostrar con punto decimal siempre
        if (cantidadTexto == "")
            cantidadTexto = Cantidad == 0 ? "" : Cantidad.ToString("F2", CultureInfo.InvariantCulture);
    }

    private void OnCantidadChange(ChangeEventArgs e)
    {
        cantidadTexto = e.Value?.ToString() ?? "";
        // Normalizar: reemplazar coma por punto
        var normalizado = cantidadTexto.Replace(",", ".");
        // Si tiene más de un punto, es inválido
        if (normalizado.Count(c => c == '.') > 1)
        {
            errorCantidad = "Formato inválido. Usa punto como decimal: 620.57";
            return;
        }
        if (decimal.TryParse(normalizado, NumberStyles.Any, CultureInfo.InvariantCulture, out var valor))
        {
            errorCantidad = "";
            CantidadChanged.InvokeAsync(valor);
        }
        else
        {
            errorCantidad = "Ingresa un número válido. Ej: 620.57";
        }
    }
}
