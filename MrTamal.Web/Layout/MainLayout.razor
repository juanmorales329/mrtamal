@inherits LayoutComponentBase
@inject AuthService AuthSvc
@inject NavigationManager Nav
@inject ApiService Api
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<div class="main-layout">
    <!-- Top navbar (móvil) -->
    <nav class="top-navbar">
        <button class="hamburger-btn" @onclick="ToggleMenu" aria-label="Menú">
            <span class="@(menuAbierto ? "icon-x" : "icon-menu")"></span>
        </button>
        <div class="brand">
            <img src="/logo-mrtamal.png" alt="MrTamal" onerror="this.style.display='none'" />
            <span>MrTamal</span>
        </div>
        <AuthorizeView>
            <Authorized>
                <button class="btn btn-sm btn-outline-danger" @onclick="Logout">Salir</button>
            </Authorized>
        </AuthorizeView>
    </nav>

    <!-- Overlay para cerrar menú en móvil -->
    @if (menuAbierto)
    {
        <div class="sidebar-overlay" @onclick="CerrarMenu"></div>
    }

    <!-- Modal alerta días sin registrar (aparece al iniciar sesión) -->
    @if (mostrarAlertaDias)
    {
        var alertColor = diasSinRegistrar >= 7 ? "#C62828" : diasSinRegistrar >= 3 ? "#E65100" : "#F57F17";
        var alertBg = diasSinRegistrar >= 7 ? "#FFEBEE" : diasSinRegistrar >= 3 ? "#FFF3E0" : "#FFFDE7";
        var emoji = diasSinRegistrar >= 7 ? "🚨" : "⚠️";
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:3000;display:flex;align-items:center;justify-content:center">
            <div style="background:white;border-radius:16px;max-width:420px;width:90%;box-shadow:0 8px 40px rgba(0,0,0,0.25);overflow:hidden;animation:slideIn .3s ease">
                <div style="background:@alertColor;padding:16px 20px;display:flex;align-items:center;gap:12px">
                    <span style="font-size:2rem">@emoji</span>
                    <div>
                        <div style="color:white;font-weight:800;font-size:1.1rem">
                            @(diasSinRegistrar == 1 ? "1 día sin registrar" : $"{diasSinRegistrar} días sin registrar")
                        </div>
                        <div style="color:rgba(255,255,255,.85);font-size:.82rem">Ingresos pendientes de actualizar</div>
                    </div>
                </div>
                <div style="padding:20px;background:@alertBg">
                    <p style="margin:0 0 8px;font-size:.92rem;color:#333">
                        Último registro: <strong>@ultimaFechaTexto</strong>
                    </p>
                    <p style="margin:0;font-size:.85rem;color:#666">
                        Tienes ingresos sin registrar. Actualiza los datos para mantener tus reportes al día.
                    </p>
                </div>
                <div style="padding:16px 20px;display:flex;gap:10px;justify-content:flex-end;border-top:1px solid #eee">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CerrarAlertaDias">
                        Recordar después
                    </button>
                    <a href="/ingresos" class="btn btn-sm text-white fw-bold" style="background:@alertColor;border-radius:6px" @onclick="CerrarAlertaDias">
                        📝 Registrar ahora
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Aviso de registros pendientes -->
    @if (mostrarAviso)
    {
        <div style="position:fixed;bottom:24px;right:24px;z-index:2000;max-width:340px;animation:slideIn .3s ease">
            <div class="card border-0 shadow-lg" style="border-left:5px solid #FF6D00 !important;border-radius:12px">
                <div class="card-body py-3 px-4">
                    <div class="d-flex align-items-start gap-3">
                        <span style="font-size:1.8rem;line-height:1">⚠️</span>
                        <div style="flex:1">
                            <div class="fw-bold" style="color:#E65100;font-size:.95rem">Registros pendientes</div>
                            <div class="text-muted" style="font-size:.82rem;margin-top:2px">
                                No hay ingresos registrados del <strong>@fechaAvisoTexto</strong>. ¿Deseas ingresarlos ahora?
                            </div>
                            <div class="d-flex gap-2 mt-2">
                                <a href="/ingresos" class="btn btn-sm text-white fw-bold" style="background:#FF6D00;border-radius:6px;font-size:.8rem" @onclick="CerrarAviso">
                                    + Ingresar ahora
                                </a>
                                <button class="btn btn-sm btn-outline-secondary" style="border-radius:6px;font-size:.8rem" @onclick="CerrarAvisoHoy">
                                    Recordar mañana
                                </button>
                            </div>
                        </div>
                        <button class="btn-close" style="font-size:.7rem" @onclick="CerrarAviso"></button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Sidebar -->
    <aside class="sidebar @(menuAbierto ? "sidebar-open" : "")" style="width:240px;position:fixed;top:0;left:0;bottom:0;z-index:999;background:#1a1a2e;display:flex;flex-direction:column;overflow-y:auto">
        <div class="sidebar-header">
            <img src="/logo-mrtamal.png" alt="MrTamal" onerror="this.style.display='none'" />
            <div>
                <div class="fw-bold text-white">MR TAMAL</div>
                <small style="color:#FFD0A0;font-size:10px">Sistema de Control</small>
            </div>
            <button class="close-sidebar-btn" @onclick="CerrarMenu">✕</button>
        </div>

        <AuthorizeView>
            <Authorized Context="authCtx">
                <div class="sidebar-user">
                    <span class="user-avatar">@authCtx.User.Identity?.Name?[..1].ToUpper()</span>
                    <div>
                        <div class="text-white small fw-bold">@authCtx.User.Identity?.Name</div>
                        <div style="color:#FFD0A0;font-size:11px">@GetRol(authCtx.User)</div>
                    </div>
                </div>
                <!-- Sucursal activa -->
                <button class="sidebar-sucursal-btn" @onclick="CambiarSucursal">
                    <span style="font-size:1rem">🏪</span>
                    <div style="flex:1;min-width:0">
                        <div style="font-size:.7rem;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.05em">Sucursal activa</div>
                        <div style="font-size:.82rem;color:white;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                            @(string.IsNullOrEmpty(sucursalNombre) ? "Sin seleccionar" : sucursalNombre)
                        </div>
                    </div>
                    <span style="color:rgba(255,255,255,.4);font-size:.75rem">⇄</span>
                </button>
            </Authorized>
        </AuthorizeView>

        <nav class="sidebar-nav">
            <NavMenu OnNavClick="CerrarMenu" />
        </nav>

        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-outline-light btn-sm w-100" @onclick="Logout">🚪 Cerrar Sesión</button>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    <!-- Contenido principal -->
    <main class="main-content" style="margin-left:240px;min-height:100vh;background:#f5f5f5;overflow-x:hidden">
        <article style="padding:20px">
            @Body
        </article>
    </main>
</div>

@code {
    private bool menuAbierto = false;
    private string sucursalNombre = "";
    private bool mostrarAviso = false;
    private string fechaAvisoTexto = "";
    private const string AvisoKey = "avisoRegistroFecha";

    // Alerta días sin registrar
    private bool mostrarAlertaDias = false;
    private int diasSinRegistrar = 0;
    private string ultimaFechaTexto = "";
    private const string AlertaDiasKey = "alertaDiasSesion";

    protected override async Task OnInitializedAsync()
    {
        sucursalNombre = await AuthSvc.GetSucursalActivaNombreAsync();
        await VerificarAvisoPendiente();
        await VerificarDiasSinRegistrar();
    }

    private async Task VerificarDiasSinRegistrar()
    {
        try
        {
            // Solo mostrar una vez por sesión
            var sesionKey = await localStorage.GetItemAsync<string>(AlertaDiasKey);
            var hoy = DateTime.Today.ToString("yyyy-MM-dd");
            if (sesionKey == hoy) return;

            var ultima = await Api.GetUltimaFechaIngresoAsync();
            if (!ultima.HasValue) return;

            var dias = (DateTime.Today.AddDays(-1) - ultima.Value.Date).Days;
            if (dias >= 1)
            {
                diasSinRegistrar = dias;
                ultimaFechaTexto = ultima.Value.ToString("dddd dd/MM/yyyy");
                mostrarAlertaDias = true;
            }
        }
        catch { }
    }

    private async Task CerrarAlertaDias()
    {
        mostrarAlertaDias = false;
        await localStorage.SetItemAsync(AlertaDiasKey, DateTime.Today.ToString("yyyy-MM-dd"));
    }

    private async Task VerificarAvisoPendiente()
    {
        try
        {
            // Solo mostrar después de las 6 PM hora local
            var ahora = DateTime.Now;
            if (ahora.Hour < 18) return;

            var ayer = ahora.Date.AddDays(-1);

            // No molestar si ya se cerró el aviso hoy
            var ultimoAviso = await localStorage.GetItemAsync<string>(AvisoKey);
            if (ultimoAviso == ahora.Date.ToString("yyyy-MM-dd")) return;

            // No mostrar en fin de semana (sábado=6, domingo=0) si ayer fue viernes
            // Verificar si hay ingresos del día anterior
            var tieneRegistros = await Api.TieneIngresosEnFechaAsync(ayer);
            if (!tieneRegistros)
            {
                fechaAvisoTexto = ayer.ToString("dddd dd/MM/yyyy");
                mostrarAviso = true;
            }
        }
        catch { }
    }

    private async Task CerrarAviso()
    {
        mostrarAviso = false;
        await localStorage.SetItemAsync(AvisoKey, DateTime.Now.Date.ToString("yyyy-MM-dd"));
    }

    private async Task CerrarAvisoHoy()
    {
        mostrarAviso = false;
        // Guardar para no molestar hasta mañana
        await localStorage.SetItemAsync(AvisoKey, DateTime.Now.Date.ToString("yyyy-MM-dd"));
    }

    private void ToggleMenu() => menuAbierto = !menuAbierto;
    private void CerrarMenu() => menuAbierto = false;

    private void CambiarSucursal()
    {
        CerrarMenu();
        Nav.NavigateTo("seleccionar-sucursal");
    }

    private async Task Logout()
    {
        await AuthSvc.LogoutAsync();
        Nav.NavigateTo("login");
    }

    private string GetRol(System.Security.Claims.ClaimsPrincipal user) =>
        user.Claims.FirstOrDefault(c => c.Type == "rol")?.Value ?? "Usuario";
}
