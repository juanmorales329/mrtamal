@inherits LayoutComponentBase
@inject AuthService AuthSvc
@inject NavigationManager Nav

<div class="main-layout">
    <!-- Top navbar (móvil) -->
    <nav class="top-navbar">
        <button class="hamburger-btn" @onclick="ToggleMenu" aria-label="Menú">
            <span class="@(menuAbierto ? "icon-x" : "icon-menu")"></span>
        </button>
        <div class="brand">
            <img src="/logo-mrtamal.png" alt="MrTamal" onerror="this.style.display='none'" />
            <span>MrTamal</span>
        </div>
        <AuthorizeView>
            <Authorized>
                <button class="btn btn-sm btn-outline-danger" @onclick="Logout">Salir</button>
            </Authorized>
        </AuthorizeView>
    </nav>

    <!-- Overlay para cerrar menú en móvil -->
    @if (menuAbierto)
    {
        <div class="sidebar-overlay" @onclick="CerrarMenu"></div>
    }

    <!-- Sidebar -->
    <aside class="sidebar @(menuAbierto ? "sidebar-open" : "")">
        <div class="sidebar-header">
            <img src="/logo-mrtamal.png" alt="MrTamal" onerror="this.style.display='none'" />
            <div>
                <div class="fw-bold text-white">MR TAMAL</div>
                <small style="color:#FFD0A0;font-size:10px">Sistema de Control</small>
            </div>
            <button class="close-sidebar-btn" @onclick="CerrarMenu">✕</button>
        </div>

        <AuthorizeView>
            <Authorized Context="authCtx">
                <div class="sidebar-user">
                    <span class="user-avatar">@authCtx.User.Identity?.Name?[..1].ToUpper()</span>
                    <div>
                        <div class="text-white small fw-bold">@authCtx.User.Identity?.Name</div>
                        <div style="color:#FFD0A0;font-size:11px">@GetRol(authCtx.User)</div>
                    </div>
                </div>
                <!-- Sucursal activa -->
                <button class="sidebar-sucursal-btn" @onclick="CambiarSucursal">
                    <span style="font-size:1rem">🏪</span>
                    <div style="flex:1;min-width:0">
                        <div style="font-size:.7rem;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.05em">Sucursal activa</div>
                        <div style="font-size:.82rem;color:white;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                            @(string.IsNullOrEmpty(sucursalNombre) ? "Sin seleccionar" : sucursalNombre)
                        </div>
                    </div>
                    <span style="color:rgba(255,255,255,.4);font-size:.75rem">⇄</span>
                </button>
            </Authorized>
        </AuthorizeView>

        <nav class="sidebar-nav">
            <NavMenu OnNavClick="CerrarMenu" />
        </nav>

        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-outline-light btn-sm w-100" @onclick="Logout">🚪 Cerrar Sesión</button>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    <!-- Contenido principal -->
    <main class="main-content">
        <article class="content-area">
            @Body
        </article>
    </main>
</div>

@code {
    private bool menuAbierto = false;
    private string sucursalNombre = "";

    protected override async Task OnInitializedAsync()
    {
        sucursalNombre = await AuthSvc.GetSucursalActivaNombreAsync();
    }

    private void ToggleMenu() => menuAbierto = !menuAbierto;
    private void CerrarMenu() => menuAbierto = false;

    private void CambiarSucursal()
    {
        CerrarMenu();
        Nav.NavigateTo("seleccionar-sucursal");
    }

    private async Task Logout()
    {
        await AuthSvc.LogoutAsync();
        Nav.NavigateTo("login");
    }

    private string GetRol(System.Security.Claims.ClaimsPrincipal user) =>
        user.Claims.FirstOrDefault(c => c.Type == "rol")?.Value ?? "Usuario";
}
