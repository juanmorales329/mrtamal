@using Microsoft.AspNetCore.Components.Routing

<AuthorizeView>
    <Authorized Context="authCtx">
        <div class="nav-items">
            <NavItem Href="" Icon="🏠" Label="Inicio" Match="NavLinkMatch.All" OnClick="OnNavClick" />

            <!-- Solo roles que manejan movimientos -->
            <AuthorizeView Roles="Admin,Gerente,Contador,Usuario" Context="c1">
                <NavItem Href="ingresos" Icon="💰" Label="Ingresos" OnClick="OnNavClick" />
                <NavItem Href="egresos" Icon="💸" Label="Egresos" OnClick="OnNavClick" />
            </AuthorizeView>

            <!-- Catálogos -->
            <AuthorizeView Roles="Admin,Gerente" Context="c2">
                <NavItem Href="catalogos" Icon="📋" Label="Catálogos" OnClick="OnNavClick" />
            </AuthorizeView>

            <!-- Reportes y Proyectado: Contador, Reportes y superiores -->
            <AuthorizeView Roles="Admin,Gerente,Contador,Reportes" Context="c3">
                <NavItem Href="reportes" Icon="📊" Label="Reportes" OnClick="OnNavClick" />
                <NavItem Href="proyectado" Icon="🎯" Label="Proyectado" OnClick="OnNavClick" />
            </AuthorizeView>

            <!-- Carga masiva y menú -->
            <AuthorizeView Roles="Admin,Gerente" Context="c4">
                <NavItem Href="carga-masiva" Icon="📤" Label="Carga Masiva" OnClick="OnNavClick" />
                <NavItem Href="menu" Icon="🌮" Label="Menú Público" OnClick="OnNavClick" />
            </AuthorizeView>

            <!-- Administración solo Admin -->
            <AuthorizeView Roles="Admin" Context="c5">
                <div class="nav-section-title">ADMINISTRACIÓN</div>
                <NavItem Href="sucursales" Icon="🏪" Label="Sucursales" OnClick="OnNavClick" />
                <NavItem Href="usuarios" Icon="👥" Label="Usuarios y Roles" OnClick="OnNavClick" />
            </AuthorizeView>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter] public EventCallback OnNavClick { get; set; }
}
