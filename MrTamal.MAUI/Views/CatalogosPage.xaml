<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MrTamal.MAUI.Views.CatalogosPage"
             Title="Catálogos">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Clicked="OnNuevoClicked" />
    </ContentPage.ToolbarItems>

    <CollectionView x:Name="Lista" SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <SwipeView>
                    <SwipeView.RightItems>
                        <SwipeItems>
                            <SwipeItem Text="Editar" BackgroundColor="{StaticResource Primary}"
                                       Invoked="OnEditarSwipe" />
                        </SwipeItems>
                    </SwipeView.RightItems>
                    <Grid Padding="16,12" ColumnDefinitions="Auto,*,Auto">
                        <Frame Grid.Column="0" BackgroundColor="{StaticResource Primary}" Padding="6,3"
                               CornerRadius="6" Margin="0,0,10,0">
                            <Label Text="{Binding Codigo}" TextColor="White" FontSize="12" FontAttributes="Bold" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="{Binding Descripcion}" FontAttributes="Bold" />
                            <Label Text="{Binding Tipo}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="{Binding Activo, Converter={StaticResource BoolToEstado}}"
                               FontSize="12" VerticalOptions="Center" />
                    </Grid>
                </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
